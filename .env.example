# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventlab?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EventLab.uz <noreply@eventlab.uz>"

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Throttler (rate limit)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
